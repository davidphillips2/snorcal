# Snorcal environment configuration.
# Copy to `.env` and edit. All values are optional — app runs with defaults.

# ---- Server ----
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ---- Storage ----
# Where SQLite DB, models, jobs, and output gcode are kept.
DATA_DIR=/data

# Frontend static files (only needed if backend serves frontend in production).
# Defaults to ../frontend/dist relative to backend dist.
# FRONTEND_DIR=/app/frontend/dist

# ---- Redis (job queue sidecar) ----
# Optional. When unreachable, app falls back to in-process async slicing
# (no persistence, concurrency=1, jobs lost on restart).
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Slicer sidecars (bambuddy or any AFKFelix/orca-slicer-api compatible) ----
# Snorcal talks to one sidecar URL per engine. Different engines can share a
# URL (single sidecar running both) or be separate services. Unset → falls
# back to local binary (dev mode on macOS).
#
# bambuddy defaults:
#   orcaslicer  → http://orca-slicer-api:3003
#   bambustudio → http://bambu-studio-api:3001
SLICER_URL_ORCASLICER=http://orca-slicer-api:3003
SLICER_URL_BAMBUSTUDIO=http://bambu-studio-api:3001

# Legacy: single SLICER_URL still works as a fallback for both engines.
# Emits a deprecation warning on first use.
# SLICER_URL=http://slicer:3001

# ---- Diagnostics ----
# Set to 1 to enable verbose MQTT/printer adapter logs.
# DEBUG_PRINTER=1
