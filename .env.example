# Snorcal environment configuration.
# Copy to `.env` and edit. All values are optional — app runs with defaults.

# ---- Server ----
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ---- Storage ----
# Where SQLite DB, models, jobs, and output gcode are kept.
DATA_DIR=/data

# Frontend static files (only needed if backend serves frontend in production).
# Defaults to ../frontend/dist relative to backend dist.
# FRONTEND_DIR=/app/frontend/dist

# ---- Redis (job queue sidecar) ----
# Optional. When unreachable, app falls back to in-process async slicing
# (no persistence, concurrency=1, jobs lost on restart).
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Slicer sidecar ----
# When set, slice jobs are dispatched to a remote HTTP slicer service
# instead of spawning the binary locally. Required in the slim app image
# (which ships no slicer binaries).
SLICER_URL=http://localhost:3001

# Slicer datadir — where Orca/Bambu read their system profiles.
# Defaults to a per-engine path under the user's config dir.
# SLICER_DATADIR=/config

# ---- Diagnostics ----
# Set to 1 to enable verbose MQTT/printer adapter logs.
# DEBUG_PRINTER=1

# =====================================================================
# The following apply only to the slicer-sidecar container/service:
# =====================================================================
# SLICER_PORT=3001
# SLICER_HOST=0.0.0.0
# DISPLAY=:99
